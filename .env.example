# Supabase (backend + auth)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Invite code for /register (server-side only — never exposed to the client)
REGISTRATION_SECRET=olivier27

# Gemini AI creative analysis
# Free tier key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Meta Marketing API — optional, for live account sync
META_ACCESS_TOKEN=
META_APP_ID=
META_APP_SECRET=

# Cron endpoint authentication (/api/cron/sync-all)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=

# Google OAuth — Automation → Calendrier. Google Cloud Console →
# APIs & Services → Credentials → OAuth 2.0 Client ID (Web application).
# Add the redirect URI below to the authorized redirect URIs list.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:4137/api/auth/google/callback
